# Anthropic API (analyst only — agent sessions use Max subscription)
ANTHROPIC_API_KEY=sk-ant-xxx

# Jira
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_USER_EMAIL=your-email@example.com

# Azure DevOps (intake normalization only — write-back not yet implemented)
# ADO_ORG_URL=https://dev.azure.com/your-org
# ADO_PAT=your-personal-access-token

# GitHub (operator's token — used by L1/L3 services)
GITHUB_TOKEN=ghp_xxx

# Agent GitHub identity (dedicated agent account — used for commits/PRs)
# AGENT_GH_TOKEN=ghp_xxx_agent
# AGENT_GIT_NAME=XCentium Agent
# AGENT_GIT_EMAIL=xcagent.rockwell@xcentium.com

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret

# Internal API auth (protects /api/* endpoints — leave empty for local dev)
# API_KEY=your-api-key

# Figma (optional — design extraction skipped if empty)
# FIGMA_API_TOKEN=figd_xxx

# L2 Dispatch
DEFAULT_CLIENT_REPO=/path/to/your/client/repo
# DEFAULT_CLIENT_PROFILE=your-profile-name

# Queue (optional — falls back to in-process background tasks if empty)
# REDIS_URL=redis://localhost:6379/0

# Session timeouts (optional overrides)
# AGENT_TIMEOUT_SECONDS=5400
# L3_SESSION_TIMEOUT=1800

# Service
LOG_LEVEL=INFO
